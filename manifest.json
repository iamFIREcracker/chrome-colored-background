{
  "manifest_version": 3,
  "name": "Colored Background",
  "version": "1.0.0",
  "description": "Inject CSS to recolor the current page's foreground/background, tmux-style (press Alt+W, then 0-6).",
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Colored Background (press 0-6)",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["schemes.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+W"
      },
      "description": "Open the color picker for the current page"
    }
  }
}
